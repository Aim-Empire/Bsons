  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h1 class="text-5xl font-bold text-center mb-12 neon-green">Plans & Pricing</h1>

    <div class="glass rounded-3xl p-8 md:p-12">
      <img src="../assets/images/plans-hero.jpg" alt="Bsons Inc Plans & Pricing Overview" class="w-full rounded-2xl mb-8 shadow-2xl shadow-green-900/30" loading="lazy">

      <h2 class="text-3xl font-semibold mb-6 neon-green text-center">Choose Your Perfect Plan</h2>
      <p class="text-lg mb-10 text-center">
        From beginner access to full AI bot suite — we have 5 tiers designed for every trader.  
        All plans include community access. Higher tiers unlock more powerful bots.
      </p>

      <!-- Pricing Cards -->
      <div class="grid md:grid-cols-5 gap-6 mb-12">
        <!-- Starter -->
        <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform">
          <h3 class="text-2xl font-bold mb-4 neon-green">Starter</h3>
          <div class="text-4xl font-bold mb-2">$55</div>
          <p class="text-sm text-gray-400 mb-6">per month</p>
          <ul class="text-left text-sm space-y-3 mb-6">
            <li>✓ 1–2 Basic Bots</li>
            <li>✓ Community Access</li>
            <li>✓ Limited Signals</li>
            <li>✗ Advanced AI</li>
          </ul>
          <a href="#" onclick="selectPlan('starter', 55)" class="block bg-green-600 hover:bg-green-500 py-3 rounded-lg font-medium">Select Starter</a>
        </div>

        <!-- Pro -->
        <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform">
          <h3 class="text-2xl font-bold mb-4 neon-green">Pro</h3>
          <div class="text-4xl font-bold mb-2">$99</div>
          <p class="text-sm text-gray-400 mb-6">per month</p>
          <ul class="text-left text-sm space-y-3 mb-6">
            <li>✓ 5+ Advanced Bots</li>
            <li>✓ Priority Signals</li>
            <li>✓ Basic Mentorship</li>
            <li>✗ Custom Bots</li>
          </ul>
          <a href="#" onclick="selectPlan('pro', 99)" class="block bg-green-600 hover:bg-green-500 py-3 rounded-lg font-medium">Select Pro</a>
        </div>

        <!-- Elite -->
        <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform border-2 border-green-500 relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-600 text-white px-4 py-1 rounded-full text-sm font-bold">Popular</span>
          <h3 class="text-2xl font-bold mb-4 neon-green">Elite</h3>
          <div class="text-4xl font-bold mb-2">$199</div>
          <p class="text-sm text-gray-400 mb-6">per month</p>
          <ul class="text-left text-sm space-y-3 mb-6">
            <li>✓ Full AI Bot Suite</li>
            <li>✓ Live Signals + Alerts</li>
            <li>✓ Expert Sessions</li>
            <li>✗ Personal Manager</li>
          </ul>
          <a href="#" onclick="selectPlan('elite', 199)" class="block bg-green-600 hover:bg-green-500 py-3 rounded-lg font-medium">Select Elite</a>
        </div>

        <!-- VIP -->
        <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform">
          <h3 class="text-2xl font-bold mb-4 neon-green">VIP</h3>
          <div class="text-4xl font-bold mb-2">$399</div>
          <p class="text-sm text-gray-400 mb-6">per month</p>
          <ul class="text-left text-sm space-y-3 mb-6">
            <li>✓ All Bots + Custom Config</li>
            <li>✓ 24/7 Priority Support</li>
            <li>✓ Profit Sharing</li>
            <li>✗ Dedicated Manager</li>
          </ul>
          <a href="#" onclick="selectPlan('vip', 399)" class="block bg-green-600 hover:bg-green-500 py-3 rounded-lg font-medium">Select VIP</a>
        </div>

        <!-- Ultimate -->
        <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform">
          <h3 class="text-2xl font-bold mb-4 neon-green">Ultimate</h3>
          <div class="text-4xl font-bold mb-2">$799</div>
          <p class="text-sm text-gray-400 mb-6">per month</p>
          <ul class="text-left text-sm space-y-3 mb-6">
            <li>✓ Unlimited Bots</li>
            <li>✓ Personal Bot Development</li>
            <li>✓ Dedicated Account Manager</li>
            <li>✓ High-Frequency Strategies</li>
          </ul>
          <a href="#" onclick="selectPlan('ultimate', 799)" class="block bg-green-600 hover:bg-green-500 py-3 rounded-lg font-medium">Select Ultimate</a>
        </div>
      </div>

      <!-- Custom Price Button -->
      <div class="text-center mt-12">
        <a href="custom-request.html" class="inline-block bg-purple-600 hover:bg-purple-500 px-12 py-6 rounded-xl text-2xl font-bold shadow-lg shadow-purple-500/30">
          Need More Power? Custom Price →
        </a>
        <p class="text-sm text-gray-400 mt-4">Contact us for enterprise, custom bots, or higher limits</p>
      </div>

      <div class="text-center mt-8">
        <a href="../index.html" class="text-green-400 hover:underline">← Back to Home</a>
      </div>
    </div>
  </main>

  <!-- Plan Selection Popup -->
  <div id="plan-popup">
    <div id="plan-box">
      <i class="fas fa-check-circle text-6xl text-green-400 mb-6"></i>
      <h2 class="text-3xl font-bold mb-4 neon-green">Plan Selected!</h2>
      <p class="text-lg mb-6" id="plan-message">Redirecting to checkout...</p>
    </div>
  </div>

  <!-- Footer -->
<!-- Minimal Footer -->
<footer class="bg-black/90 border-t border-gray-800 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
    <img src="../assets/images/logo.png" alt="Bsons Inc" class="h-10 mx-auto mb-4">
    <p class="text-sm text-gray-500">© 2026 Bsons Inc Crypto Hub. All rights reserved.</p>
