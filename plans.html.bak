<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Plans & Pricing – Bsons Inc Crypto Hub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <style>
    body { background: radial-gradient(circle at center, #0f172a 0%, #020617 80%); color: #e2e8f0; }
    .glass { background: rgba(15,23,42,0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); }
    .neon-green { color: #10b981; text-shadow: 0 0 10px #10b981; }

    /* Rectangular Popup for plan selection */
    #plan-popup {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }
    #plan-popup.visible {
      opacity: 1;
      pointer-events: auto;
    }
    #plan-box {
      background: #0f172a;
      border: 3px solid #10b981;
      width: 90%;
      max-width: 520px;
      padding: 2.5rem 2rem;
      text-align: center;
      box-shadow: 0 0 40px rgba(16, 185, 129, 0.6);
    }
  </style>
</head>
<body class="min-h-screen">

