/* Universal Popup for ALL forms */
function showPopup(message) {
  const popup = document.createElement('div');
  popup.innerHTML = `
    <div class="fixed inset-0 bg-black/85 flex items-center justify-center z-50">
      <div class="bg-[#0f172a] border-4 border-[#10b981] w-11/12 max-w-lg p-8 md:p-12 text-center shadow-[0_0_50px_rgba(16,185,129,0.6)]">
        <i class="fas fa-check-circle text-6xl text-green-400 mb-6"></i>
        <h2 class="text-3xl font-bold mb-4 neon-green">Success!</h2>
        <p class="text-lg mb-6">${message}</p>
      </div>
    </div>
  `;
  document.body.appendChild(popup);
  setTimeout(() => popup.remove(), 5000);
}

/* Attach to all forms */
document.querySelectorAll('form').forEach(form => {
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    showPopup('Request sent! Our team will contact you soon.');
    form.reset();
  });
});
</script>
<!-- Universal Smart Popup - Custom Message for Each Button/Form -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // Shared popup function
  function showPopup(title, message) {
    const popup = document.createElement('div');
    popup.innerHTML = `
      <div class="fixed inset-0 bg-black/85 flex items-center justify-center z-50">
        <div class="bg-[#0f172a] border-4 border-[#10b981] w-11/12 max-w-lg p-8 md:p-12 text-center shadow-[0_0_50px_rgba(16,185,129,0.6)]">
          <i class="fas fa-check-circle text-6xl text-green-400 mb-6"></i>
          <h2 class="text-3xl font-bold mb-4 neon-green">${title}</h2>
          <p class="text-lg mb-6">${message}</p>
        </div>
      </div>
    `;
    document.body.appendChild(popup);
    setTimeout(() => popup.remove(), 5000); // Auto-fade after 5 seconds
  }

  // 1. Login Form
  const loginForm = document.getElementById('login-form');
  if (loginForm) {
    loginForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Login Successful!', 'Welcome back!<br>Redirecting to your Plans page...');
      setTimeout(() => window.location.href = "plans.html", 5000);
    });
  }

  // 2. Get Started / Sign Up Form
  const getStartedForm = document.getElementById('get-started-form');
  if (getStartedForm) {
    getStartedForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Account Created!', 'Welcome to Bsons Inc!<br>Check your email to verify and start.');
      setTimeout(() => window.location.href = "plans.html", 5000);
    });
  }

  // 3. Custom Request Form
  const customForm = document.getElementById('custom-request-form');
  if (customForm) {
    customForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Custom Request Sent!', 'Our team will contact you within 24 hours with a personalized quote.');
      customForm.reset();
    });
  }

  // 4. Long Term Investment Form
  const longTermForm = document.getElementById('long-term-form');
  if (longTermForm) {
    longTermForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Long-Term Request Sent!', 'Our team will contact you within 48 hours with your strategy.');
      longTermForm.reset();
    });
  }

  // 5. Newsletter Subscribe (on index.html)
  const newsletterForm = document.getElementById('newsletter-form');
  if (newsletterForm) {
    newsletterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Subscribed!', 'Thank you! Check your email for confirmation and updates.');
      newsletterForm.reset();
    });
  }

  // 6. Contact Form (on contact or index)
  const contactForm = document.getElementById('contact-form');
  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showPopup('Message Sent!', 'Thank you! We will get back to you soon.');
      contactForm.reset();
    });
  }

  // 7. Plan Selection Buttons on Plans page
  document.querySelectorAll('a[onclick^="selectPlan"], a[href="#"]:not([onclick])').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const planText = btn.textContent.trim() || btn.closest('.glass').querySelector('h3').textContent.trim();
      showPopup('Plan Selected!', `${planText} chosen!<br>Redirecting to checkout...`);
      setTimeout(() => window.location.href = "checkout.html", 3000);
    });
  });
});
</script>

<!-- Fixed Hamburger Menu Toggle - Works on ALL pages -->
<script>
const menuToggle = document.getElementById('menu-toggle');
const mobileMenu = document.getElementById('mobile-menu');

if (menuToggle && mobileMenu) {
  menuToggle.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
    console.log('Hamburger clicked!');
  });
  
  document.addEventListener('click', (e) => {
    if (!mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
      mobileMenu.classList.add('hidden');
    }
  });
}
</script>
</body>
</html>
