</div>
  </div>
</div>
  </div>
</div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <h1 class="text-5xl font-bold text-center mb-12 neon-green">Custom Plan Request</h1>

    <div class="glass rounded-3xl p-8 md:p-12 max-w-4xl mx-auto">
      <p class="text-xl text-center mb-8">
        Need something beyond our standard plans? Tell us exactly what you want — we’ll build a custom package just for you.
      </p>

      <form id="custom-form" class="space-y-6">
        <div>
          <label class="block text-lg font-medium mb-2">Your Name</label>
          <input type="text" required placeholder="Full Name" class="w-full px-6 py-4 rounded-xl bg-gray-900 border border-gray-700 focus:border-green-500 focus:outline-none">
        </div>

        <div>
          <label class="block text-lg font-medium mb-2">Email Address</label>
          <input type="email" required placeholder="you@example.com" class="w-full px-6 py-4 rounded-xl bg-gray-900 border border-gray-700 focus:border-green-500 focus:outline-none">
        </div>

        <div>
          <label class="block text-lg font-medium mb-2">Desired Features / Bots</label>
          <textarea rows="4" required placeholder="Example: 10+ custom AI bots, high-frequency trading, dedicated server, etc." class="w-full px-6 py-4 rounded-xl bg-gray-900 border border-gray-700 focus:border-green-500 focus:outline-none resize-none"></textarea>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-lg font-medium mb-2">Monthly Budget</label>
            <input type="text" placeholder="$500 – $5000 (or range)" class="w-full px-6 py-4 rounded-xl bg-gray-900 border border-gray-700 focus:border-green-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-lg font-medium mb-2">Preferred Payment Method</label>
            <select class="w-full px-6 py-4 rounded-xl bg-gray-900 border border-gray-700 focus:border-green-500 focus:outline-none">
              <option>Crypto (BTC, ETH, USDT, etc.)</option>
              <option>Credit/Debit Card</option>
              <option>Bank Transfer</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <div class="text-center mt-10">
          <button type="submit" class="inline-block bg-purple-600 hover:bg-purple-500 px-12 py-6 rounded-xl text-2xl font-bold shadow-lg shadow-purple-500/30">
            Send Custom Request
          </button>
        </div>
      </form>

      <p class="text-center text-sm text-gray-400 mt-8">
        We'll review your request and reply within 24 hours with a custom quote.
      </p>

      <div class="text-center mt-8">
        <a href="plans.html" class="text-green-400 hover:underline">← Back to Plans</a>
        <span class="mx-4 text-gray-500">•</span>
        <a href="../index.html" class="text-green-400 hover:underline">Back to Home</a>
      </div>
    </div>
  </main>

  <!-- Footer -->
<!-- Minimal Footer -->
<footer class="bg-black/90 border-t border-gray-800 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
    <img src="../assets/images/logo.png" alt="Bsons Inc" class="h-10 mx-auto mb-4">
    <p class="text-sm text-gray-500">© 2026 Bsons Inc Crypto Hub. All rights reserved.</p>
  </div>
</footer>

  <!-- Rectangular Visible Popup -->
  <div id="success-popup">
    <div id="popup-box">
      <i class="fas fa-check-circle text-6xl text-green-400 mb-6"></i>
      <h2 class="text-3xl font-bold mb-4 neon-green">Request Sent!</h2>
      <p class="text-lg mb-6">Custom plan request sent successfully!<br>Our team will contact you within 24 hours with a personalized quote.</p>
    </div>
  </div>

  <!-- Scripts -->
  <script>
    // Mobile menu toggle
function closeMenu() { mobileMenu.classList.remove('translate-x-0'); mobileMenu.classList.add('translate-x-full'); }

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

}

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

}
    }

    // Form submit → show popup
    const form = document.getElementById('custom-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault(); // prevent page reload
        showPopup();
        this.reset(); // clear form
      });
    }

    function showPopup() {
      const popup = document.getElementById('success-popup');
      popup.classList.add('visible');
      setTimeout(() => {
        popup.classList.remove('visible');
      }, 5000); // stay visible for 5 seconds
    }
  </script>

<!-- Universal Modern Mobile Menu Upgrade (Works on ALL pages) -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const oldMenu = document.getElementById('mobile-menu');
  if (!oldMenu) return;
  const newMenu = document.createElement('div');
  newMenu.id = 'mobile-menu';
  newMenu.className = 'fixed inset-0 bg-black/60 backdrop-blur-sm z-50 translate-x-full transition-transform duration-500 ease-in-out';
  newMenu.innerHTML = `
    <div class="absolute right-0 top-0 h-full w-4/5 max-w-sm bg-gray-900/95 backdrop-blur-xl border-l border-green-500/30 shadow-2xl overflow-y-auto">
      <button id="menu-close" class="absolute top-5 right-5 text-white text-3xl focus:outline-none hover:text-green-400 transition">
        <i class="fas fa-times"></i>
      </button>
      <div class="px-8 py-20 space-y-8 text-center">
        <a href="pages/community.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">Community</a>
        <a href="pages/plans.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">Plans</a>
        <a href="pages/long-term.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">Long Term Investment</a>
        <a href="pages/blog.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">Blog</a>
        <a href="pages/faqs.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">FAQs</a>
        <a href="pages/contact.html" class="block text-xl font-medium text-gray-200 hover:text-green-400 transition-all duration-300 transform hover:scale-105 hover:font-semibold">Contact Us</a>
      </div>
    </div>
  `;
  oldMenu.replaceWith(newMenu);
function closeMenu() { mobileMenu.classList.remove('translate-x-0'); mobileMenu.classList.add('translate-x-full'); }
  function closeMenu() { mobileMenu.classList.remove('translate-x-0'); mobileMenu.classList.add('translate-x-full'); }
  console.log('Modern mobile menu activated!');
});
</script>
<!-- Fixed Menu Script + Universal Popups -->
<script>

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);

if (mobileMenu) {
  mobileMenu.addEventListener('click', (e) => {
    if (e.target === mobileMenu) closeMenu();
  });
}
function closeMenu() { mobileMenu.classList.remove('translate-x-0'); mobileMenu.classList.add('translate-x-full'); }
if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);
if (mobileMenu) { mobileMenu.addEventListener('click', (e) => { if (e.target === mobileMenu) closeMenu(); }); }
function closeMenu() { mobileMenu.classList.remove('translate-x-0'); mobileMenu.classList.add('translate-x-full'); }
if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);
if (mobileMenu) { mobileMenu.addEventListener('click', (e) => { if (e.target === mobileMenu) closeMenu(); }); }

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);

if (mobileMenu) {
  mobileMenu.addEventListener('click', (e) => {
    if (e.target === mobileMenu) closeMenu();
  });
}

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);

if (mobileMenu) {
  mobileMenu.addEventListener('click', (e) => {
    if (e.target === mobileMenu) closeMenu();
  });
}

function closeMenu() {
  mobileMenu.classList.remove('translate-x-0');
  mobileMenu.classList.add('translate-x-full');
}

if (menuToggle) menuToggle.addEventListener('click', openMenu);
if (menuClose) menuClose.addEventListener('click', closeMenu);

if (mobileMenu) {
  mobileMenu.addEventListener('click', (e) => {
    if (e.target === mobileMenu) closeMenu();
  });
}

/* Universal Popup for ALL forms */
function showPopup(message) {
  const popup = document.createElement('div');
  popup.innerHTML = `
    <div class="fixed inset-0 bg-black/85 flex items-center justify-center z-50">
      <div class="bg-[#0f172a] border-4 border-[#10b981] w-11/12 max-w-lg p-8 md:p-12 text-center shadow-[0_0_50px_rgba(16,185,129,0.6)]">
        <i class="fas fa-check-circle text-6xl text-green-400 mb-6"></i>
        <h2 class="text-3xl font-bold mb-4 neon-green">Success!</h2>
        <p class="text-lg mb-6">${message}</p>
      </div>
    </div>
  `;
  document.body.appendChild(popup);
  setTimeout(() => popup.remove(), 5000);
}

/* Attach to all forms */
document.querySelectorAll('form').forEach(form => {
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    showPopup('Request sent! Our team will contact you soon.');
    form.reset();
  });
});
</script>
<!-- Fixed Hamburger Menu Toggle - Works on ALL pages -->
<script>
const menuToggle = document.getElementById('menu-toggle');
const mobileMenu = document.getElementById('mobile-menu');

if (menuToggle && mobileMenu) {
  menuToggle.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
    console.log('Hamburger clicked!');
  });
  
  document.addEventListener('click', (e) => {
    if (!mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
      mobileMenu.classList.add('hidden');
    }
  });
}
</script>
</body>
</html>
